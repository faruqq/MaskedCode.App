<Window x:Class="MaskedCode.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MaskedCode"
        Width="1200"
        Height="820"
        MinWidth="900"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="Kaynak dil:" />

            <ComboBox x:Name="LanguageComboBox"
                      Grid.Column="1"
                      Height="32"
                      VerticalContentAlignment="Center"
                      SelectionChanged="LanguageComboBox_SelectionChanged"
                      SelectedIndex="0">
                <ComboBoxItem Content="PL/I"
                              Tag="PL1" />

                <ComboBoxItem Content="EGL"
                              Tag="EGL" />

                <ComboBoxItem Content="C# / .NET"
                              Tag="CSharp" />
            </ComboBox>

            <Button Grid.Column="3"
                    MinWidth="110"
                    Height="32"
                    Padding="12,0"
                    Click="SelectFileButton_Click"
                    Content="Dosya Seç" />

            <TextBlock x:Name="SelectedFileTextBlock"
                       Grid.Column="4"
                       Margin="12,0"
                       VerticalAlignment="Center"
                       Text="Dosya seçilmedi"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text,
                                         RelativeSource={RelativeSource Self}}" />

            <Button x:Name="MaskButton"
                    Grid.Column="5"
                    MinWidth="120"
                    Height="32"
                    Padding="16,0"
                    Click="MaskButton_Click"
                    Content="Maskele"
                    IsEnabled="False" />
        </Grid>

        <GroupBox Grid.Row="2"
                  Header="Maskeleme Yöntemi">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <RadioButton x:Name="MaximumPrivacyRadioButton"
                                 GroupName="MaskingMode"
                                 Content="Maksimum Gizlilik"
                                 IsChecked="True"
                                 Checked="MaskingModeRadioButton_Checked"
                                 ToolTip="Değerlerin uzunluğunu ve yapısını mümkün olduğunca gizler." />

                    <TextBlock Margin="22,4,0,0"
                               Foreground="#FF4B5563"
                               Text="Identifier ve değerlerin yapısını mümkün olduğunca gizler. Varsayılan ve daha güvenli seçenektir."
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <RadioButton x:Name="FormatPreservingRadioButton"
                                 GroupName="MaskingMode"
                                 Content="Biçim Korumalı"
                                 Checked="MaskingModeRadioButton_Checked"
                                 ToolTip="Karakter uzunluğunu, harf-rakam türünü ve ayraçları korur." />

                    <TextBlock Margin="22,4,0,0"
                               Foreground="#FF4B5563"
                               Text="Uzunluğu, büyük-küçük harf düzenini ve ayraç konumlarını korur; sınırlı biçim bilgisi gösterebilir."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="Kaynak Kod" />

                <TextBox x:Name="SourceCodeTextBox"
                         Grid.Row="2"
                         Padding="10"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="14"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="SourceCodeTextBox_TextChanged"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="Maskelenmiş Kod" />

                <TextBox x:Name="MaskedCodeTextBox"
                         Grid.Row="2"
                         Padding="10"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="14"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />

                <StackPanel Grid.Row="4"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button x:Name="CopyButton"
                            MinWidth="100"
                            Height="32"
                            Padding="12,0"
                            Click="CopyButton_Click"
                            Content="Kopyala"
                            IsEnabled="False" />

                    <Button x:Name="SaveFileButton"
                            MinWidth="130"
                            Height="32"
                            Margin="8,0,0,0"
                            Padding="12,0"
                            Click="SaveFileButton_Click"
                            Content="Dosyayı Kaydet"
                            IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="6"
                Padding="10,7"
                Background="#FFF3F4F6"
                CornerRadius="4">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Kod yapıştırabilir veya bir kaynak dosya seçebilirsiniz."
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>